# Recommended: set these in Dokploy/production env. If left empty, Docker
# generates stable values in the shared autowp_runtime volume on first boot.
SECRET_KEY=
FERNET_KEY=
POSTGRES_USER=autowp
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=autowpdb
DATABASE_URL=postgresql://autowp:change-me@postgres:5432/autowpdb
REDIS_URL=redis://redis:6379/0

# Shared AI config is stored from the Admin Settings UI after first login.
GEMINI_API_KEY=

# Comma-separated Google account emails that should become admins on login.
# The first registered user is still promoted to admin automatically.
ADMIN_EMAILS=

# Optional integrations configured from Admin Settings.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
PAYMENT_TRIPAY_ENABLED=true
PAYMENT_PAYPAL_ENABLED=true
PAYMENT_MANUAL_ENABLED=true
ALLOW_MOCK_PAYMENTS=false
